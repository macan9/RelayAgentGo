# RelayAgentGo online integration template

CONTROLLER_BASE_URL=http://139.196.158.225:8080
CONTROLLER_TOKEN=
RELAY_NAME=relay-01

# Optional. Leave empty to let OwnZeroTierController assign/return the network id.
ZT_NETWORK_ID=

# ZeroTier interfaces usually start with "zt".
ZT_INTERFACE_PREFIX=zt

# Optional probes. Leave empty to skip.
PUBLIC_IP_PROBE_URL=
LATENCY_PROBE_URL=http://139.196.158.225:8080/health

LOG_LEVEL=info
STATE_PATH=/var/lib/relay-agent/state.json
HEARTBEAT_INTERVAL_SECONDS=30
HTTP_TIMEOUT_SECONDS=10
CONTROLLER_RETRY_MAX=2
CONTROLLER_RETRY_WAIT_MS=200

# Keep true for first online integration.
# It registers, heartbeats, fetches config, and reports generated commands without changing local networking.
DRY_RUN=true
