# Local build/package settings
APP_NAME=relay-agent
VERSION=dev
BUILD_DIR=./.deploy-dist

# Remote host settings
REMOTE_HOST=139.196.158.225
REMOTE_USER=root
REMOTE_PORT=22

# Remote install paths
REMOTE_BASE_DIR=/opt/relay-agent-go
REMOTE_RELEASES_DIR=/opt/relay-agent-go/releases
REMOTE_CURRENT_LINK=/opt/relay-agent-go/current
REMOTE_CONFIG_DIR=/etc/relay-agent
REMOTE_ENV_FILE=/etc/relay-agent/relay-agent.env

# Runtime/state paths on remote host
REMOTE_STATE_DIR=/var/lib/relay-agent
REMOTE_LOG_DIR=/var/log/relay-agent

# Optional verification against controller
# CONTROLLER_BASE_URL=https://controller.example.com
# CONTROLLER_TOKEN=change-me
# RELAY_NODE_ID=relay-01
